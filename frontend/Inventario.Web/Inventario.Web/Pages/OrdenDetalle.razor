@page "/ordenes/{IdOrden:int}"
@inject Inventario.Web.Services.ApiService Api
@inject NavigationManager Nav

<h3>Detalle orden #@IdOrden</h3>

@if (cargando)
{
    <p>Cargando...</p>
}
else if (detalle is null)
{
    <p>No existe la orden.</p>
}
else
{
    <p><b>Estado:</b> @detalle.Orden.Estado</p>
    <p><b>Proveedor:</b> @detalle.Orden.Proveedor</p>

    <div class="mb-3">
        <label>Producto</label>
        <select class="form-select" @bind="idProducto">
            @foreach (var p in productos)
            {
                <option value="@p.IdProducto">@p.Nombre</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Cantidad</label>
        <input class="form-control" type="number" min="1" @bind="cantidad" />
    </div>

    <div class="mb-3">
        <label>Precio estimado (opcional)</label>
        <input class="form-control" type="number" step="0.01" @bind="precio" />
    </div>

    <button class="btn btn-primary" @onclick="AgregarLinea">Añadir línea</button>

    <div class="mt-3">
        <button class="btn btn-outline-secondary me-2" @onclick="Enviar" disabled="@(detalle.Orden.Estado != "BORRADOR")">
            Marcar ENVIADA
        </button>

        <button class="btn btn-success" @onclick="Recibir" disabled="@(detalle.Orden.Estado != "ENVIADA")">
            Recibir (actualiza stock)
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <p class="mt-3">@mensaje</p>
    }

    <hr />

    <h5>Líneas</h5>

    @if (detalle.Lineas.Count == 0)
    {
        <p>Sin líneas.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in detalle.Lineas)
                {
                    <tr>
                        <td>@l.Producto</td>
                        <td>@l.Cantidad</td>
                        <td>@l.PrecioEstimado</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public int IdOrden { get; set; }

    bool cargando = true;
    ApiService.OrdenDetalleDto? detalle;

    List<ApiService.ProductoSimpleDto> productos = new();
    int idProducto;
    int cantidad = 1;
    decimal? precio;

    string? mensaje;

    protected override async Task OnInitializedAsync()
    {
        var ok = await Api.TryLoadTokenAsync();
        if (!ok) { Nav.NavigateTo("/login"); return; }

        productos = await Api.GetProductosSimpleAsync();
        if (productos.Count > 0) idProducto = productos[0].IdProducto;

        await Cargar();
    }

    async Task Cargar()
    {
        cargando = true;
        detalle = await Api.GetOrdenDetalleAsync(IdOrden);
        cargando = false;
    }

    async Task AgregarLinea()
    {
        mensaje = null;
        var ok = await Api.AgregarLineaAsync(IdOrden, idProducto, cantidad, precio);
        mensaje = ok ? "Línea añadida ✅" : "No se pudo añadir ❌";
        await Cargar();
    }

    async Task Enviar()
    {
        mensaje = null;
        var ok = await Api.CambiarEstadoOrdenAsync(IdOrden, "ENVIADA");
        mensaje = ok ? "Orden marcada como ENVIADA ✅" : "No se pudo cambiar estado ❌";
        await Cargar();
    }

    async Task Recibir()
    {
        mensaje = null;
        var ok = await Api.RecibirOrdenAsync(IdOrden);
        mensaje = ok ? "Orden recibida ✅ (stock actualizado)" : "Error recibiendo orden ❌";
        await Cargar();
    }
}